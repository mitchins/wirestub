{
  "log": {
    "entries": [
      {
        "request": {
          "method": "POST",
          "url": "https://api.example.com/secure?access_token=token-value",
          "headers": [
            { "name": "Authorization", "value": "Bearer super-secret-token" },
            { "name": "Cookie", "value": "cookie-session-value" },
            { "name": "X-API-Key", "value": "api-key-secret" },
            { "name": "Content-Type", "value": "application/json" }
          ],
          "queryString": [
            { "name": "access_token", "value": "token-value" }
          ],
          "postData": {
            "mimeType": "application/json",
            "text": "{\"access_token\":\"really-secret\",\"password\":\"hunter2\"}"
          }
        },
        "response": {
          "status": 200,
          "headers": [
            { "name": "Set-Cookie", "value": "session=abcd" },
            { "name": "Content-Type", "value": "application/json" }
          ],
          "content": {
            "mimeType": "application/json",
            "text": "{\"refresh_token\":\"refresh-secret\"}"
          }
        }
      }
    ]
  }
}
